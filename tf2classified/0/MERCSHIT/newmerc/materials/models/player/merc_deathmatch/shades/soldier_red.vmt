"VertexLitGeneric"
{
	"$basetexture" "models\player\soldier\red\soldier_red"
	"$bumpmap" "models\player\soldier\soldier_normal"

	// Phong paramaters
	"$phong" "1"
	"$phongdisablehalflambert" "1"
	"$phongexponent" "10"
	"$phongboost" "1.3"
	"$phongfresnelranges" "[.3 1 8]"
	"$lightwarptexture" "models\player\pyro\lambert_lightwarp"

	// Rim lighting parameters
	"$rimlight" "1"
	"$rimlightexponent" "4"
	"$rimlightboost" "2"

	// Burn overlay
	"$detail" "effects\tiledfire\firelayeredslowtiled512"
	"$detailscale" "5"
	"$detailblendfactor" "0"
	"$detailblendmode" "6"

	// Cloaking
	"$cloakpassenabled" "1"

	"Proxies"
	{
		"invis"
		{
		}
		"AnimatedTexture"
		{
			"animatedtexturevar" "$detail"
			"animatedtextureframenumvar" "$detailframe"
			"animatedtextureframerate" "30"
		}
		"BurnLevel"
		{
			"resultVar" "$detailblendfactor"
		}
	}
}